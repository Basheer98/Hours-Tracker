# PostgreSQL — prefer a single connection URL (use Railway’s “Reference” from the Postgres service)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway"
#
# If DATABASE_URL is broken, you can use libpq-style vars instead (set all of these):
# PGHOST=…
# PGPORT=5432
# PGUSER=…
# PGPASSWORD=…
# PGDATABASE=…

# Shared secret: same value must be entered in the app under Settings → Server API key
DTC_API_KEY="use-a-long-random-string"

# Optional; Railway sets PORT automatically
# PORT=8787

# If Postgres is not ready, still start HTTP (API returns 503 until DB works) — for debugging on Railway
# ALLOW_START_WITHOUT_DB=1

# Local dev: leave unset so the API accepts requests without a key (only for development)
# NODE_ENV=production
